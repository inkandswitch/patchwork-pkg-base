{
  "name": "module-settings-manager",
  "title": "Module Settings Manager",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "sync": "vite build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "dependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.0.4",
    "@inkandswitch/patchwork-elements": "^0.0.6",
    "solid-automerge": "^1.1.0"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.5",
    "@automerge/automerge-repo": "^2.6.0-subduction.9",
    "@inkandswitch/patchwork-filesystem": "^0.0.4",
    "@inkandswitch/patchwork-plugins": "^0.0.6",
    "@node-types/node": "npm:@types/node@^24.9.1",
    "solid-js": "^1.9.10",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.11.10"
  }
}
