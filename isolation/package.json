{
  "name": "@patchwork/isolation",
  "title": "Patchwork Isolation",
  "version": "0.0.1",
  "description": "Tool isolation as a patchwork-base component — sandboxed-iframe rendering with an allowlist/denylist-gated intermediary repo.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "generate:esms": "node scripts/generate-esms-source.mjs",
    "prebuild": "pnpm generate:esms",
    "build": "vite build",
    "dev": "pnpm generate:esms && vite build --watch",
    "sync": "pnpm build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [],
  "author": "Ink & Switch",
  "license": "MIT",
  "dependencies": {
    "@automerge/automerge-repo": "^2.6.0-subduction.26",
    "@automerge/automerge-repo-network-messagechannel": "^2.6.0-subduction.26",
    "@inkandswitch/patchwork-elements": "1.0.0",
    "@inkandswitch/patchwork-filesystem": "^0.0.8",
    "@inkandswitch/patchwork-plugins": "^0.0.11",
    "@inkandswitch/patchwork-providers": "0.3.0",
    "debug": "^4.4.3",
    "es-module-shims": "^2.8.1"
  },
  "devDependencies": {
    "@inkandswitch/patchwork-bootloader": "^0.2.8",
    "typescript": "^5.6.0",
    "vite": "^7.1.9"
  }
}
