{
  "name": "@grjte/codemirror-base",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "source": "./src/main.tsx"
    },
    "./tool": {
      "import": "./dist/tool.js",
      "source": "./src/tool.tsx"
    },
    "./component": {
      "import": "./dist/lib/codemirror.js",
      "source": "./src/lib/codemirror.tsx"
    }
  },
  "scripts": {
    "build": "node esbuild/build.ts",
    "dev": "node esbuild/watch.ts",
    "pushwatch": "pnpm dev pushwork",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "dependencies": {
    "@automerge/automerge-codemirror": "^0.2.0",
    "@automerge/automerge-repo-solid-primitives": "^2.6.0-subduction.26",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.4",
    "@inkandswitch/annotations": "^0.1.6",
    "@inkandswitch/annotations-diff": "^0.1.6",
    "@inkandswitch/patchwork-bootloader": "link:../../patchwork-next/core/bootloader",
    "@inkandswitch/patchwork-filesystem": "^0.0.8",
    "@inkandswitch/patchwork-plugins": "^0.0.11",
    "@inkandswitch/patchwork-providers": "file:../../patchwork-next/packages/providers/core/dist/inkandswitch-patchwork-providers-0.2.2.tgz",
    "@inkandswitch/patchwork-providers-solid": "file:../../patchwork-next/packages/providers/frameworks/solid/dist/inkandswitch-patchwork-providers-solid-0.2.3.tgz",
    "solid-js": "^1.9.9",
    "vite-plugin-wasm": "^3.5.0"
  },
  "devDependencies": {
    "@automerge/automerge": "3.3.0-fragments.1",
    "@automerge/automerge-repo": "^2.6.0-subduction.26",
    "@babel/core": "^7.28.4",
    "@babel/parser": "^7.28.4",
    "@eslint/js": "^9.36.0",
    "@node-types/node": "npm:@types/node@^24.9.1",
    "@types/babel__core": "^7.20.5",
    "babel-preset-solid": "^1.9.9",
    "esbuild": "^0.23.1",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}
