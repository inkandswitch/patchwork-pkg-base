{
  "name": "@patchwork/chitterchatter",
  "version": "0.4.0",
  "description": "chitterchatter: chat with emoji reactions, presence/typing indicators, image paste, voice notes, and message replies.",
  "type": "module",
  "main": "./main.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "push": "pnpm build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "keywords": [
    "chat",
    "reactions",
    "voice-notes",
    "presence"
  ],
  "author": "chee",
  "dependencies": {
    "@automerge/automerge": "^3.2.1",
    "@automerge/automerge-repo": "^2.5.0",
    "@automerge/automerge-repo-solid-primitives": "^2.5.1",
    "@chee/patchwork-llm": "automerge:HaCFnBBADdADqJm4Bu5Sc4abQyE",
    "@inkandswitch/patchwork-elements": "^0.0.5",
    "@inkandswitch/patchwork-filesystem": "^0.0.3",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@chee/patchwork-bundles": "^0.0.1",
    "@inkandswitch/patchwork-bootloader": "^0.0.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.10.0"
  }
}
