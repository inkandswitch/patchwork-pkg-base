{
  "name": "@chee/patchwork-sideboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "patchwork": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "source": "./src/index.tsx"
    },
    "./tools/sideboard": {
      "import": "./dist/sideboard/sideboard.js",
      "patchwork": "./dist/sideboard/sideboard.js",
      "source": "./src/sideboard/sideboard.tsx"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "node esbuild/build.ts",
    "dev": "node esbuild/watch.ts",
    "pushwatch": "pnpm dev pushwork",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "dependencies": {
    "@automerge/automerge-repo-solid-primitives": "2.5.2",
    "@kobalte/core": "^0.13.11",
    "@inkandswitch/patchwork-bootloader": "^0.0.4",
    "@inkandswitch/patchwork-elements": "^0.0.6",
    "@types/debug": "^4.1.12",
    "debug": "^4.4.3",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.5",
    "@automerge/automerge-repo": "^2.6.0-subduction.9",
    "@automerge/automerge-repo-keyhive": "^0.2.0-alpha.1d",
    "@babel/core": "7.28.4",
    "@babel/parser": "7.28.4",
    "@inkandswitch/annotations-context": "^0.1.4",
    "@inkandswitch/annotations-selection": "^0.1.5",
    "@inkandswitch/patchwork-filesystem": "^0.0.4",
    "@inkandswitch/patchwork-plugins": "^0.0.6",
    "@inkandswitch/subscribables-solid": "^0.1.2",
    "@node-types/node": "npm:@types/node@^24.9.1",
    "@solid-primitives/map": "^0.7.2",
    "@types/babel__core": "^7.20.5",
    "babel-preset-solid": "^1.9.9",
    "esbuild": "^0.23.1",
    "solid-devtools": "^0.34.4",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "22.21.0"
  }
}
