{
  "name": "@patchwork/contact",
  "version": "0.0.0",
  "description": "contact datatype and viewer",
  "type": "module",
  "private": true,
  "main": "./dist/tool.js",
  "exports": {
    ".": {
      "import": "./dist/tool.js",
      "source": "./src/tool.tsx"
    },
    "./style.css": "./dist/tool.css"
  },
  "scripts": {
    "build": "node esbuild/build.ts",
