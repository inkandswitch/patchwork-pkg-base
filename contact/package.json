    "@node-types/node": "npm:@types/node@^24.9.1",
    "@tailwindcss/vite": "^4.1.15",
    "@types/react": "^18.3.23",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.5.1",
    "esbuild": "^0.23.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "^5.8.3"
