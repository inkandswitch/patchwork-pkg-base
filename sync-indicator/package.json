{
  "name": "@tiny-patchwork/sync-indicator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "source": "./src/index.tsx"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "pushwatch": "pnpm dev pushwork",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@automerge/automerge-repo": "^2.6.0-subduction.9",
    "@automerge/automerge-repo-solid-primitives": "^2.5.2",
    "@inkandswitch/patchwork-bootloader": "^0.3.2",
    "@inkandswitch/patchwork-plugins": "^0.0.6",
    "@types/debug": "^4.1.12",
    "debug": "^4.4.3",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "esbuild": "~0.25.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.9",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-top-level-await": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "~0.25.0"
    }
  }
}
