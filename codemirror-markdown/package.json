{
  "name": "@grjte/codemirror-markdown",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "source": "./src/main.tsx"
    },
    "./markdown": {
      "import": "./dist/extensions/markdown.js",
      "source": "./src/extensions/markdown.ts"
    },
    "./markdown-links": {
      "import": "./dist/extensions/links.js",
      "source": "./src/extensions/links.ts"
    },
    "./markdown-embed": {
      "import": "./dist/extensions/embed.js",
      "source": "./src/extensions/embed.ts"
    },
    "./datatype": {
      "import": "./dist/datatype.js",
      "source": "./src/datatype.ts"
    }
  },
  "scripts": {
    "build": "node esbuild/build.ts",
    "dev": "node esbuild/watch.ts",
    "pushwatch": "pnpm dev pushwork",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@codemirror/autocomplete": "^6.19.0",
    "@codemirror/commands": "^6.9.0",
    "@codemirror/lang-markdown": "^6.4.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.4",
    "@lezer/highlight": "^1.2.1",
    "@lezer/markdown": "^1.6.3",
    "@inkandswitch/patchwork-bootloader": "^0.0.4",
    "@inkandswitch/patchwork-plugins": "^0.0.6"
  },
  "devDependencies": {
    "@automerge/automerge-repo": "^2.6.0-subduction.9",
    "@babel/core": "^7.28.4",
    "@babel/parser": "^7.28.4",
    "@eslint/js": "^9.36.0",
    "@node-types/node": "npm:@types/node@^24.9.1",
    "@types/babel__core": "^7.20.5",
    "esbuild": "^0.23.1",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}
